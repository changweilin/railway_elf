# Copy to .env (which is git-ignored) and fill in your real values.
#
# Get these by registering at https://tdx.transportdata.tw/ and creating an
# API key in 會員中心 → API金鑰管理. See scripts/TDX-SETUP.md for full flow.
#
# Only needed when running scripts/fetch-rail-shapes.mjs without --skip-tw.
# The web app itself NEVER reads these — they live build-time only.

TDX_CLIENT_ID=
TDX_CLIENT_SECRET=
